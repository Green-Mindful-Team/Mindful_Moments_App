{
  "expo": {
    "name": "Mindful Journal",
    "slug": "mindful-journaling-app",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.mindfuljournal.app"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#ffffff"
      },
      "package": "com.mindfuljournal.app"
    },
    "web": {},
    "plugins": [
      "expo-av",
      "expo-secure-store"
    ]
  }
}
